{
  // Cloudflare Workers: static files from ./public + proxy /api, /uploads, /health → API_ORIGIN (your Node host).
  // Deploy: npm run deploy:cf  |  Dev: npm run dev:cf (needs .dev.vars + npm start)
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sellitnow",
  "main": "cloudflare/proxy-worker.js",
  "compatibility_date": "2025-09-27",
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
