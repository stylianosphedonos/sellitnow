# Server
NODE_ENV=development
PORT=3000

# Public site URL (email verification / password reset links). Use your Cloudflare Workers or custom domain, e.g. https://sellitnow.your-subdomain.workers.dev
API_BASE_URL=http://localhost:3000

# Behind Cloudflare Worker proxy + host (e.g. Render): hop count for Express. Default 1. Try 2 if req.ip is wrong.
# TRUST_PROXY=1

# Cloudflare: Worker variable API_ORIGIN = this Node app’s HTTPS origin (Render/Railway/Fly). Also accepted: UPSTREAM_ORIGIN or SELLITNOW_API.
# If /api/* returns 503: open https://<worker>/cf-worker-ping — if api_origin_configured is false, add API_ORIGIN in the dashboard.
# If true, open API_ORIGIN/health in a browser; 503 usually means the host is down, sleeping (free tier), or the app crashed on boot.

# Database
# Leave unset to use SQLite (default: <STORAGE_ROOT>/data/sellitnow.db).
# Set to your Render Postgres "Internal Database URL" (or external URL with sslmode=require) to use PostgreSQL.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SQLITE_DB_PATH=./data/sellitnow.db
# Optional: force SSL options for managed Postgres (defaults on when URL hints Render/AWS or sslmode=require).
# DATABASE_SSL=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (get keys from https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
EMAIL_FROM=Sellitnow <noreply@sellitnow.com>

# App
VAT_RATE=0.20
SHIPPING_COST=5.99
# Storage root (Render persistent disk sets RENDER_DISK_ROOT automatically)
# STORAGE_ROOT=/var/data
# UPLOAD_DIR default: <STORAGE_ROOT>/uploads
UPLOAD_DIR=./uploads
# Public URL prefix to serve uploaded files
UPLOAD_URL_PREFIX=/uploads
MAX_IMAGE_SIZE_MB=5
MAX_IMAGES_PER_PRODUCT=5
