# Server
NODE_ENV=development
PORT=3000

# Public site URL (email verification / password reset links). Use your Cloudflare Workers or custom domain, e.g. https://sellitnow.your-subdomain.workers.dev
API_BASE_URL=http://localhost:3000

# Behind Cloudflare Worker proxy + host (e.g. Render): hop count for Express. Default 1. Try 2 if req.ip is wrong.
# TRUST_PROXY=1

# Cloudflare Workers (wrangler.jsonc): set API_ORIGIN to this Node app’s public HTTPS URL (Render/Railway/Fly). Dashboard → Worker → Variables, or wrangler secret put API_ORIGIN
# Optional: plain-text variable in dashboard overrides empty vars.API_ORIGIN from the repo.

# Database
DATABASE_URL=postgresql://localhost:5432/sellitnow

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (get keys from https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
EMAIL_FROM=Sellitnow <noreply@sellitnow.com>

# App
VAT_RATE=0.20
SHIPPING_COST=5.99
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
MAX_IMAGES_PER_PRODUCT=5
